# Banco PostgreSQL. Use a URL do Neon, Supabase ou outro Postgres.
# Exemplo Neon: postgresql://usuario:senha@host/database?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Crie uma chave grande e aleatória para assinar a sessão.
# Exemplo rápido: openssl rand -base64 32
JWT_SECRET="troque-por-uma-chave-secreta-grande"

# URL do app em produção. Localmente use http://localhost:3000
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Para apenas visualizar o sistema localmente sem configurar PostgreSQL.
# Use somente em desenvolvimento.
DEMO_MODE="true"
