# Neon Postgres
# DATABASE_URL: use a URL "Pooled connection"; o host tem "-pooler".
DATABASE_URL="postgresql://USER:PASSWORD@EP-EXEMPLO-pooler.REGIAO.aws.neon.tech/neondb?sslmode=require"

# DIRECT_URL: use a URL "Direct connection"; o host nao tem "-pooler".
DIRECT_URL="postgresql://USER:PASSWORD@EP-EXEMPLO.REGIAO.aws.neon.tech/neondb?sslmode=require"

# Chave usada para assinar o cookie de sessao.
JWT_SECRET="troque-por-uma-chave-secreta-grande"

# Opcional. O codigo atual nao depende desta variavel.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
